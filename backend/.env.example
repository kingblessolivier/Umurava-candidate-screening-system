PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<username>:<p\assword>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_MAX_RETRIES=8
MONGODB_RETRY_DELAY_MS=2000
MONGODB_RETRY_MAX_DELAY_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SOCKET_TIMEOUT_MS=45000

GEMINI_API_KEY=your_gemini_api_key

# Resume parsing: fast, cost-effective model (no thinking required)
RESUME_PARSER_MODEL=gemini-2.0-flash-exp

# Screening/evaluation: capable model with thinking support
SCREENING_MODEL=gemini-2.5-pro
SCREENING_THINKING_BUDGET=2048

JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
